{
  "installCommand": "npm install",
  "buildCommand": "npm -w @scratch/shared run build && npm -w @scratch/web run build:deploy",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "includeFiles": "apps/api/src/**,packages/shared/src/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
